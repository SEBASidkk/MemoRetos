---
import AppLayout from '../../layouts/AppLayout.astro';
import MemoretosPage from '../../components/react/MemoretosPage';
import { getMyMemoretos } from '../../lib/api';

const token = Astro.locals.token;
const res = await getMyMemoretos(token);
const memos = (res.data as { memoretos?: unknown[] }).memoretos ?? [];
---

<AppLayout title="Mis Memoretos">
  <MemoretosPage initialMemos={memos as Parameters<typeof MemoretosPage>[0]['initialMemos']} client:load />
</AppLayout>
